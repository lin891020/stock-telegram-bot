[Unit]
Description=Stock Telegram Bot
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/stock-telegram-bot
ExecStart=/home/ubuntu/stock-telegram-bot/venv/bin/python main.py
Restart=always
RestartSec=10
EnvironmentFile=/home/ubuntu/stock-telegram-bot/.env

[Install]
WantedBy=multi-user.target
